{
  "manifest_version": "1.0",
  "id": "piphi-network-spi",
  "name": "PiPhi Network SPI Sensors",
  "version": "0.1.0",
  "description": "Local SPI environmental sensor integration for BME680, BME280, BMP280, and compatible SPI sensor boards.",
  "maintainer": {
    "name": "PiPhi Integrations Team",
    "website": "https://github.com/PiPhi-io"
  },
  "license": "Apache-2.0",
  "image": "local/piphi-network-spi",
  "platforms": ["linux"],
  "runtime": {
    "linux": {
      "type": "proxy",
      "proxy": {
        "port": 3675
      },
      "discovery": {
        "method": "proxy",
        "inputs": [
          {"name": "adapter", "label": "Adapter", "type": "select", "required": true, "options": ["linux_spi", "ft232h", "mock"], "description": "Use linux_spi for direct GPIO headers, ft232h for the Adafruit USB bridge, or mock only when PIPHI_ALLOW_MOCK_HARDWARE=true."},
          {"name": "bus", "label": "SPI Bus", "type": "number", "required": true, "placeholder": "0"},
          {"name": "chip_select", "label": "Chip Select", "type": "number", "required": true, "placeholder": "0"},
          {"name": "sensor_model", "label": "Sensor Model", "type": "select", "required": true, "options": ["auto", "bme680", "bme280", "bmp280"]},
          {"name": "baudrate", "label": "Baudrate", "type": "number", "required": true, "placeholder": "100000"}
        ]
      }
    }
  },
  "api": {
    "base_url": "http://127.0.0.1:3675",
    "required": ["health", "entities", "state", "command", "config", "ui_config"],
    "endpoints": {
      "health": "/health",
      "discover": "/discover",
      "entities": "/entities",
      "state": "/state",
      "command": "/command",
      "config": "/config",
      "config_sync": "/configs/sync",
      "deconfigure": "/deconfigure",
      "ui_config": "/ui-config",
      "events": "/events"
    }
  },
  "config": {
    "source": "endpoint",
    "endpoint": "/ui-config",
    "required": true,
    "editable_fields": ["adapter", "bus", "chip_select", "sensor_model", "baudrate", "poll_interval_seconds"],
    "identity_fields": ["adapter", "bus", "chip_select", "sensor_model"]
  },
  "identity": {
    "fields": ["adapter", "bus", "chip_select", "sensor_model"]
  },
  "capabilities": {
    "connected": {"kind": "sensor", "value_kind": "boolean", "unit": "bool", "dashboard": {"allowed_widgets": ["stat", "sensor-card", "availability-card"], "default_widget": "stat"}},
    "temperature_c": {"kind": "sensor", "value_kind": "numeric", "unit": "C", "dashboard": {"allowed_widgets": ["stat", "sensor-card", "line-chart", "room-climate-card"], "default_widget": "stat"}},
    "humidity_percent": {"kind": "sensor", "value_kind": "numeric", "unit": "%", "dashboard": {"allowed_widgets": ["stat", "sensor-card", "line-chart", "room-climate-card"], "default_widget": "stat"}},
    "pressure_hpa": {"kind": "sensor", "value_kind": "numeric", "unit": "hPa", "dashboard": {"allowed_widgets": ["stat", "sensor-card", "line-chart", "weather"], "default_widget": "stat"}},
    "gas_ohms": {"kind": "sensor", "value_kind": "numeric", "unit": "ohm", "dashboard": {"allowed_widgets": ["stat", "sensor-card", "line-chart", "air-quality-card"], "default_widget": "stat"}},
    "refresh": {"kind": "action", "value_kind": "command", "dashboard": {"allowed_widgets": ["button", "command-strip"], "default_widget": "button"}}
  },
  "commands": {
    "refresh": {
      "description": "Read the sensor immediately.",
      "timeout_ms": 5000
    }
  },
  "entities": [
    {
      "id": "spi-environmental-sensor",
      "name": "SPI Environmental Sensor",
      "device_id": "spi-environmental-sensor",
      "entity_type": "sensor",
      "capabilities": ["connected", "temperature_c", "humidity_percent", "pressure_hpa", "gas_ohms", "refresh"],
      "available_commands": [{"id": "refresh", "label": "Refresh", "kind": "action"}],
      "dashboard": {"allowed_widgets": ["sensor-card", "stat", "line-chart", "air-quality-card", "room-climate-card"], "default_widget": "sensor-card"}
    }
  ]
}
